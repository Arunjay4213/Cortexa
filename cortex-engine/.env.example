# Cortexa Engine Configuration
# All env vars are prefixed with CORTEX_

# Production URLs
# Render:  https://cortex-engine.onrender.com
# Custom:  https://api.cortexa.ink

# API
CORTEX_PORT=10000
CORTEX_ADMIN_SECRET=    # REQUIRED — generate with: openssl rand -hex 32

# Database (Neon PostgreSQL)
CORTEX_DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# Groq (for decomposition, NLI, and quote extraction)
CORTEX_GROQ_API_KEY=gsk_...
CORTEX_GROQ_MODEL=llama-3.3-70b-versatile

# NLI
CORTEX_NLI_ENTAILMENT_THRESHOLD=0.7

# Verification limits
CORTEX_MAX_CLAIMS=50
CORTEX_MAX_SOURCE_CHARS=50000

# CORS (comma-separated origins)
CORTEX_ALLOWED_ORIGINS=https://cortexa.ink  # add your dashboard URL

# For local dev, set:
# CORTEX_URL=http://localhost:8000
